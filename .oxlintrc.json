{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "unicorn",
    "typescript",
    "oxc"
  ],
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "eqeqeq": [
      "error",
      "always",
      {
        "null": "ignore"
      }
    ],
    "no-empty": [
      "warn",
      {
        "allowEmptyCatch": true
      }
    ],
    "typescript/consistent-type-imports": [
      "warn",
      {
        "prefer": "type-imports",
        "fixStyle": "separate-type-imports"
      }
    ],
    "typescript/prefer-regexp-exec": "error",
    "typescript/no-this-alias": "allow"
  },
  "env": {
    "builtin": true,
    "es2024": true,
    "node": true
  },
  "globals": {},
  "ignorePatterns": [
    "packages/@sysopkit/*/dist/**",
    "packages/*/dist/**",
    "docs/.astro/**",
    "docs/dist/**"
  ]
}
